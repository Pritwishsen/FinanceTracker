modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Personal Finance App Server"

[[workflows.workflow]]
name = "Personal Finance App Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node serve.js"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "python3 -m http.server 5000"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
